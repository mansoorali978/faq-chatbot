# faq_agent.hocon
# A two-agent network:
#   1. faq_frontman     - receives user question, manages conversation
#   2. faq_lookup_tool  - CodedTool that searches the FAQ JSON dataset

{
  "llm_config": {
    "model_name": "llama3.1",
    "base_url": "http://host.docker.internal:11434"
  },

  "tools": [
    {
      "name": "faq_frontman",
      "function": {
        "description": "I am a helpful FAQ assistant for ICICI Pru Life insurance. I answer questions about financial transactions, premium payments, claims, bank account changes, and policy management."
      },
      "instructions": "You are a helpful FAQ assistant for ICICI Pru Life insurance company. You help customers with questions about their insurance policies including bank account changes, premium payments, claims, nominations, policy documents, and surrenders. When a user asks any question, ALWAYS call FaqLookupTool first with the user's question as the query. Then use the results to give a clear and friendly answer. Never refuse to answer insurance-related questions. Always use FaqLookupTool before responding.",
      "tools": ["FaqLookupTool"]
    },
    {
      "name": "FaqLookupTool",
      "function": {
        "description": "Searches the FAQ database for answers to user questions about ICICI Pru Life insurance policies and financial transactions.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "The user's question or keywords to search in the FAQ database"
            }
          },
          "required": ["query"]
        }
      },
      "class": "faq_agent.faq_lookup_tool.FaqLookupTool"
    }
  ]
}